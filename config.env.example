# ============================================================
# COGITO-Swarm v1.2 config (key=value, plain shell-source format)
# Copy to config.env, edit per bot. No yaml parser required.
# ============================================================

# ── Bot identity ──
BOT_NAME="BaoXia"
BOT_ROLE="leader"              # leader | worker | advisor
BOT_TG_ID="MbaM3-2026"
LANGUAGE="en"

# ── Roles & model routing ──
LEADER_DEFAULT=""             # default head; leave blank to await assignment/negotiation
LEADER_NEGOTIATE_TIMEOUT_MIN=2
MODEL_LEADER="deepseek/v4-pro"
MODEL_WORKER="deepseek/v4-flash"
MODEL_ADVISOR="deepseek/v4-flash"

# ── Heartbeat (Leader only; the swarm's ONLY poller) ──
HEARTBEAT_ENABLED=true         # set false for worker/advisor
HEARTBEAT_INTERVAL_MIN=90      # heartbeat frequency; larger = cheaper
IDLE_THRESHOLD_MIN=10          # how long idle before considering proactive ideation
# Auto-trigger conditions (see cogito/GATE.md)
TRIGGER_GOAL_CONFLICT=true     # behavior drifting from core goal
TRIGGER_EXTERNAL_RISK=true     # money/time/safety/privacy risk
TRIGGER_STUCK_TASK=true        # a task stuck beyond timeout
TRIGGER_USER_ASKED=true        # user explicitly requested

# ── GATE (the proactive vs. cheap switch) ──
GATE_MAX_PROACTIVE_PER_DAY=3   # max proactive "broadcasts" per day (journaling not counted)
GATE_NOVELTY_LOOKBACK=5        # dedupe against the last N topics
GATE_RISK_MIN_THRESHOLD=0.6    # risk ≥ this counts as "worth saying"
GATE_QUIET_IF_NO_HUMAN=true    # nobody online and not a risk → journal only, don't broadcast
GATE_CONSEQUENCE_DEPTH=2       # consequence projection depth

# ── EVIDENCE / anti-hallucination ──
EVIDENCE_REQUIRED=true         # reporting "done" must attach evidence
EVIDENCE_REJECT_NO_PROOF=true  # no evidence → auto-flag UNVERIFIED
EVIDENCE_VERIFY_BY_ADVISOR=true
FACTS_SOURCE="ledger_only"     # facts only from the ledger, not group history/memory

# ── Compute/presentation separation + output contract (v1.2, absorbs Gemini) ──
COMMS_MODE="board_first"       # board_first = collaborate on board, TG broadcasts only | group = old behavior
TG_OUTPUT_ONLY=true            # only <TG_MESSAGE> may reach TG
ACTION_FIRST=true              # on an info gap, halt and emit <ACTION>; no guessing aloud
SINGLE_OUTPUT_TAG=true         # each response outputs only one tag (state-machine)

# ── CONFIDENCE (v1.2, absorbs ChatGPT/Gemini) ──
CONFIDENCE_REQUIRED=true       # reports must carry CONFIDENCE
CONFIDENCE_ASK_CLOUD=0.6       # below this → <ASK_CLOUD> to verify before finalizing
CONFIDENCE_LEARN_MIN=0.85      # threshold to promote to shared knowledge (see learning section)

# ── DELIBERATION (prevents Frankenstein/infinite loops) ──
DELIBERATION_MAX_PHASE=3       # internal negotiation at most 3 phases; no consensus → Leader force-decides
DELIBERATION_FORCE_CONVERGE=true

# ── ENSEMBLE (ask/verify with cloud LLMs) ──
# v1.1: Bagging (parallel vote / reduce variance / anti-hallucination) vs Boosting (sequential refine / reduce bias)
ENSEMBLE_ENABLED=true
ENSEMBLE_MODE="auto"           # auto | bag | boost | boost_then_bag | off
                               # auto → scripts/ensemble_route.sh picks by task type
ENSEMBLE_TRIGGER="critical"    # critical | always | off (routine tasks always skip)
# Bagging (voting verification): reviewers MUST be heterogeneous so errors are uncorrelated
BAGGING_MODELS="openrouter/openai/gpt-4.1,openrouter/anthropic/claude-sonnet-4-20250514,openrouter/google/gemini-3-pro-preview"
BAGGING_APPROVE_RATIO=0.66     # ≥2/3 to pass; tie counts as not passing
BAGGING_CHECK_EVIDENCE=true    # voting must check evidence vs. claim consistency
# Boosting (sequential refine): bound rounds to prevent drift, can early-stop
BOOSTING_CRITIC_MODEL="openrouter/anthropic/claude-sonnet-4-20250514"
BOOSTING_MAX_ROUNDS=2          # aligns with CONVENE_MAX_ROUNDS
BOOSTING_EARLY_STOP=true       # stop when critic replies NO_SIGNIFICANT_GAP

# ── Convene (multiple bots research/discuss) ──
CONVENE_MAX_ROUNDS=2           # bound discussion rounds, avoid token runaway
CONVENE_DEADLINE_MIN=10

# ── Shared board / external memory (lowers context) ──
BOARD_LOCAL_CACHE="${HOME}/.openclaw/workspace/skills/cogito-swarm/board/"
BOARD_RSYNC_HOST=""
BOARD_RSYNC_INTERVAL_MIN=5

# ── Task timeout ──
TASK_TIMEOUT_MIN=5
TASK_RETRY_MAX=2
TASK_MAX_PARALLEL=4            # OpenClaw parallel cap ~3-5

# ── Integrated learning (v1.2 quantified thresholds, absorbs ChatGPT Shared Learning Guard) ──
LEARN_AUTO_ABSORB=true
LEARN_MIN_SOURCES=2            # at least 2 independent sources (prevents one-off hallucination becoming knowledge)
LEARN_MIN_VERIFY=1            # at least 1 independent verification
LEARN_MIN_CONFIDENCE=0.85     # confidence > 0.85 to promote to shared knowledge
LEARN_REQUIRE_DUAL_CONFIRM=true
LEARN_PATH="${HOME}/.openclaw/workspace/skills/cogito-swarm/learned/"

# ── Token monitoring / budget ──
TOKEN_MONITOR_ENABLED=true
TOKEN_DAILY_BUDGET=20000       # exceeded → gate blocks everything, record only
TOKEN_ALERT_THRESHOLD_DAILY=5.00
TOKEN_LOG_PATH="${HOME}/.openclaw/workspace/skills/cogito-swarm/token_usage.log"

# ── Evaluation (whether it's actually helping) ──
EVAL_ENABLED=true
EVAL_ADOPTION_TARGET=0.6       # adoption-rate target
EVAL_AUTO_DOWNGRADE_AFTER=5    # 5 unhelpful in a row → lower proactivity

# ── Watchdog ──
WATCHDOG_ENABLED=true
WATCHDOG_CHECK_INTERVAL_MIN=10
WATCHDOG_MAX_MISSED_SYNC=3

# ── Privacy ──
PRIVACY_USER_VISIBILITY=true
PRIVACY_DATA_RETENTION_DAYS=7

# ── COMPLIANCE (v1.2, see COMPLIANCE.md) ──
AI_DISCLOSURE_REQUIRED=true        # auto-disclose AI identity on first external speech (EU AI Act Art.50)
CLOUD_PII_REDACT=true              # mask personal data before <ASK_CLOUD>/Bagging send to cloud (PDPA cross-border)
CLOUD_JURISDICTION_ALLOWLIST=""    # blank = unrestricted; recommend listing models in adequately-protected regions
ACTION_ALLOWLIST=""                # blank = unrestricted; recommend listing allowed commands/domains
ACTION_REQUIRE_HUMAN_ABOVE_RISK=0.7  # action risk ≥ this value needs human approval
CRAWLER_RESPECT_ROBOTS=true        # crawler respects robots.txt / ToS / rate limits
AUDIT_LOG_CLOUD_TRANSFERS=true     # log "which data was sent to which model" for audit
